# ── Netlify (set in Site settings → Environment variables) ──

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
REACT_APP_GA_MEASUREMENT_ID=

# Google Search Console HTML verification code
REACT_APP_GSC_VERIFICATION=

# Form submissions use FormSubmit.co → vineeshkalyanaraman5@gmail.com + harishradhakrishnan2001@gmail.com (CC)
# Activate primary inbox once via FormSubmit confirmation email on first live submission.

# ── Local development only ──

# Optional API server (not needed on Netlify — forms use FormSubmit.co)
REACT_APP_API_URL=http://localhost:5001

# Set to 0 to skip prerender postbuild locally (Netlify sets this automatically)
PRERENDER=1
